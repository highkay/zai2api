# ===================
# 服务器配置
# ===================
PORT=8000

# ===================
# API 配置
# ===================
# API 端点地址
API_ENDPOINT=https://chat.z.ai/api/v2/chat/completions

# 上游 z.ai 出口代理；留空表示直连。支持 http://、https://、socks5://、socks5h://
UPSTREAM_PROXY=

# 认证令牌（支持多个，逗号分隔）
# 用于验证客户端请求
AUTH_TOKEN=sk-your-token-here

# 备用上游令牌（支持多个，逗号分隔）
# 会导入 SQLite token ledger 作为 env_backup 来源的管理副本
BACKUP_TOKEN=

# Token SQLite 数据库路径；留空时使用 data/tokens.db
TOKEN_DB_PATH=

# 是否允许 GET /v1/tokens?reveal=true 返回完整 bearer；默认关闭
TOKEN_API_ALLOW_REVEAL=false

# ===================
# 功能配置
# ===================
# 调试日志
DEBUG_LOGGING=false

# 工具调用支持
TOOL_SUPPORT=true

# 请求失败时的重试次数（不含首次请求）
RETRY_COUNT=5

# 跳过认证令牌验证
SKIP_AUTH_TOKEN=false

# 扫描限制（字符数）
SCAN_LIMIT=200000

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===================
# 显示配置
# ===================
# 多行备注，在 / 端点显示
# 支持 | 或 \n 作为换行符
# 示例: NOTE=第一行|第二行|第三行
NOTE=
