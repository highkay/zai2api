# ===================
# 服务器配置
# ===================
PORT=8000

# ===================
# API 配置
# ===================
# API 端点地址
API_ENDPOINT=https://chat.z.ai/api/v2/chat/completions

# 聊天后端:
# - direct: 当前容器内直接发 z.ai Web 请求
# - browser_helper: 转发给外部 browser helper，由 helper 负责 page-backed chat / captcha / sticky proxy
CHAT_BACKEND=direct

# 上游 z.ai 出口代理；留空表示直连。支持 http://、https://、socks5://、socks5h://
# Docker Compose 下访问宿主机代理可用 http://host.docker.internal:7890
UPSTREAM_PROXY=

# 可选 browser helper HTTP 入口；当 CHAT_BACKEND=browser_helper 时使用
# 如果 helper 也跑在同一个 docker compose 里，建议填 http://browser-helper:39090/v1/browser-chat/completions
# 如果 helper 部署在宿主机，再通过 http://host.docker.internal:<port>/... 暴露给容器
BROWSER_HELPER_URL=

# 可选 browser helper 鉴权 token；如果 helper 开了内部鉴权，这里填 Bearer token
BROWSER_HELPER_AUTH_TOKEN=

# browser helper 调用超时（秒）
BROWSER_HELPER_TIMEOUT_SECONDS=180

# browser helper 容器端口映射
BROWSER_HELPER_PORT=39090

# ===================
# browser helper 运行配置
# ===================
# 如果使用 HELPER_PROXY_TEMPLATE，会把 {bucket} 替换为 bucket 身份
HELPER_PROXY_TEMPLATE=

# 初始 warm slot 种子 bucket；留空时会按 HELPER_SLOT_COUNT + HELPER_PROXY_BUCKET_PREFIX 自动生成
HELPER_PROXY_BUCKETS=

# warm slot 数量；当 HELPER_PROXY_BUCKETS 留空时生效
HELPER_SLOT_COUNT=4

# 自动生成 bucket 时使用的前缀，默认会形成 user_1,user_2,...
HELPER_PROXY_BUCKET_PREFIX=user

# 也可以直接显式提供完整代理 URL 数组，优先级高于 TEMPLATE/BUCKETS
HELPER_PROXY_URLS_JSON=

# helper 内部鉴权 token
HELPER_AUTH_TOKEN=

# 是否启用浏览器 headless
HELPER_HEADLESS=true

# 单个 helper 请求总超时（秒）
HELPER_REQUEST_TIMEOUT_SECONDS=120

# 单个 slot 的 page-backed chat 超时（秒）
HELPER_SLOT_REQUEST_TIMEOUT_SECONDS=45

# 页面载入后的额外等待（毫秒）
HELPER_PAGE_WAIT_MS=6000

# 单个 browser process 服务多少次后主动回收
HELPER_PROCESS_RECYCLE_REQUESTS=20

# 单个 browser process 最大存活时间（秒）
HELPER_PROCESS_MAX_AGE_SECONDS=3600

# 一般失败后的 slot cooldown（秒）
HELPER_SLOT_COOLDOWN_SECONDS=90

# 严重失败后的 slot cooldown（秒）
HELPER_SLOT_HARD_COOLDOWN_SECONDS=300

# 启动/重建 slot 前是否先做 cheap proxy preflight
HELPER_PROXY_PREFLIGHT_ENABLED=true

# proxy preflight 超时（秒）
HELPER_PROXY_PREFLIGHT_TIMEOUT_SECONDS=10

# proxy preflight 最多尝试多少个新 bucket 再放弃
HELPER_PROXY_PREFLIGHT_MAX_ATTEMPTS=4

# 认证令牌（支持多个，逗号分隔）
# 用于验证客户端请求
AUTH_TOKEN=sk-your-token-here

# 备用上游令牌（支持多个，逗号分隔）
# 会导入 SQLite token ledger 作为 env_backup 来源的管理副本
BACKUP_TOKEN=

# Token SQLite 数据库路径；留空时使用 data/tokens.db
TOKEN_DB_PATH=

# 在线运行时配置文件路径；/v1/config 会写入这里，默认在 data 下随 compose volume 持久化
RUNTIME_CONFIG_PATH=data/runtime_config.json

# 是否允许 GET /v1/tokens?reveal=true 返回完整 bearer；默认关闭
TOKEN_API_ALLOW_REVEAL=false

# ===================
# 功能配置
# ===================
# 调试日志
DEBUG_LOGGING=false

# 工具调用支持
TOOL_SUPPORT=true

# 请求失败时的重试次数（不含首次请求）
RETRY_COUNT=5

# 跳过认证令牌验证
SKIP_AUTH_TOKEN=false

# 扫描限制（字符数）
SCAN_LIMIT=200000

# 日志级别: debug, info, warn, error
LOG_LEVEL=info

# ===================
# 显示配置
# ===================
# 多行备注，在 / 端点显示
# 支持 | 或 \n 作为换行符
# 示例: NOTE=第一行|第二行|第三行
NOTE=
